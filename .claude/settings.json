{
  "permissions": {
    "allow": [
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh issue list:*)",
      "Bash(gh pr list:*)",
      "Bash(gh gist create:*)",
      "Bash(python3 _automation/*:*)",
      "Bash(Rscript:*)",
      "Bash(R:*)",
      "Bash(zip:*)",
      "Bash(uvx:*)",
      "WebFetch(domain:cran.r-project.org)",
      "WebFetch(domain:cloud.r-project.org)",
      "WebFetch(domain:packagemanager.posit.co)",
      "WebFetch(domain:bioconductor.org)"
    ],
    "deny": [
      "Bash(git reset --hard:*)",
      "Bash(gh repo delete:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "sandbox": {
    "network": {
      "allowedDomains": [
        "cran.r-project.org",
        "*.r-project.org",
        "cloud.r-project.org",
        "packagemanager.posit.co",
        "*.posit.co",
        "bioconductor.org",
        "*.bioconductor.org"
      ]
    }
  }
}
